# Public portfolio demo only. Use placeholders here.
# Real Toast, 7shifts, Google, and Vercel secrets must stay in the private repo/Vercel project.

TOAST_API_BASE_URL=https://ws-api.toasttab.com
TOAST_CLIENT_ID=replace_with_demo_or_private_value
TOAST_CLIENT_SECRET=replace_with_demo_or_private_value
TOAST_LOCATION_GUIDS={"demo-location-a":"restaurant_guid_here"}
TOAST_MANAGEMENT_GROUP_GUID=management_group_guid_here

SEVENSHIFTS_API_BASE_URL=https://api.7shifts.com/v2
SEVENSHIFTS_ACCESS_TOKEN=replace_with_private_value
SEVENSHIFTS_LOCATION_IDS={"demo-location-a":"123456"}

GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"demo"}
GOOGLE_SHEETS_SALES_ID=replace_with_sheet_id
GOOGLE_SHEETS_PRIME_COST_ID=replace_with_sheet_id

DASHBOARD_PROXY_TOKEN=replace_with_long_random_value
CRON_SECRET=replace_with_long_random_value
